# 后端环境变量示例
# 复制为 backend/.env 后再填写真实值；不要提交真实 .env、密钥、口令或内网地址。

# 服务监听端口
PORT=3000

# OpenAI 标准 Chat Completions 兼容配置；所有聊天模型统一使用这组变量
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=sk-your-llm-api-key
LLM_MODEL=your-chat-model

# 向量化模型配置；未配置 API Key 时系统会退回到本地 mock embedding，仅适合开发验证
EMBEDDING_BASE_URL=https://api.example.com/v1
EMBEDDING_API_KEY=sk-your-embedding-api-key
EMBEDDING_MODEL=your-embedding-model
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=16

# 重排模型配置；未配置 API Key 时跳过重排
RERANK_BASE_URL=https://api.example.com/v1
RERANK_API_KEY=sk-your-rerank-api-key
RERANK_MODEL=your-rerank-model

# PostgreSQL 配置；生产环境优先使用 DATABASE_URL
DATABASE_URL=postgres://contract_review:contract_review@127.0.0.1:5432/contract_review
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=contract_review
POSTGRES_PASSWORD=contract_review
POSTGRES_DB=contract_review
DB_POOL_MIN=0
DB_POOL_MAX=10

# Milvus 向量库配置；VECTOR_STORE=milvus 时使用，缺失地址会自动回退到 PostgreSQL 向量字段
VECTOR_STORE=milvus
MILVUS_ADDRESS=localhost:19530
MILVUS_COLLECTION=contract_review_knowledge
MILVUS_DATABASE=default
MILVUS_USERNAME=
MILVUS_PASSWORD=
MILVUS_TOKEN=
MILVUS_SSL=false
MILVUS_CONNECT_TIMEOUT_MS=3000

# OnlyOffice 配置；JWT_SECRET 必须与 Document Server 保持一致
ONLYOFFICE_JWT_SECRET=change-me-onlyoffice-jwt-secret
ONLYOFFICE_URL=http://localhost:8081
APP_HOST=localhost:3000
BACKEND_URL_FOR_DOCKER=host.docker.internal:3000

# 知识库初始化配置；默认初始化社会法和前 10 个裁判文书 JSON
KNOWLEDGE_SEED_TYPES=law,case
LAW_SEED_DIRS=社会法
LAW_SEED_FILE_BATCH_SIZE=20
CASE_SEED_DIR=data/candidate_55192
CASE_SEED_LIMIT=10
KNOWLEDGE_FORCE_RESEED=false

# 知识库批量导入限制
KNOWLEDGE_BATCH_FILE_LIMIT=200
KNOWLEDGE_BATCH_ENTRY_SIZE=50
KNOWLEDGE_IMPORT_FILE_SIZE_LIMIT=52428800

# 智能问答历史上下文限制
QA_MAX_HISTORY_MESSAGES=12
QA_MAX_HISTORY_CHARS=4000
